AimCoreSection:AddSlider("AimSmoothingSlider", {
    Text = "Aim Smoothing",
    Min = 1, Max = 15, Default = Settings.Smoothing, Rounding = 1,
    Callback = function(v) Settings.Smoothing = v end
})

TriggerbotSection:AddToggle("TriggerbotMasterToggle", {
