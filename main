local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- --- CONFIGURATION / STATE ---
local Settings = {
    AimbotEnabled = true,
    TargetMethod = "DynamicScan", 
    CustomTargetName = "Head",    
    FOV = 150,
    TeamCheck = false,
    VisibleCheck = true,
    
    -- Core Integrations
    Smoothing = 1,
    TriggerbotEnabled = false,
    
    -- Visual Customization
    ESPEnabled = true,
    ShowBoxes = true,
    ShowNames = true,
    ShowTracers = false,
    ShowHealth = true,
    ShowSkeleton = false,
    ShowFOV = false,
    ShowCrosshair = false,
    
    -- Dynamic Theme State Color Palettes
    BoxColor = Color3.fromRGB(10, 132, 255),
    SkeletonColor = Color3.fromRGB(255, 255, 255),
    FOVColor = Color3.fromRGB(255, 255, 255),
    CrosshairColor = Color3.fromRGB(255, 0, 0) 
}

local Aiming = false
local TriggerbotHolding = false
local ActiveConnections = {}
local esps = {}

local R15Links = {
    {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
    {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
    {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"},
    {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"}
}
local R6Links = {
    {"Head", "Torso"},
    {"Torso", "Left Arm"}, {"Torso", "Right Arm"},
    {"Torso", "Left Leg"}, {"Torso", "Right Leg"}
}

-- --- INITIALIZE OBSIDIAN / LINORIA UI ---
