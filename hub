--// Loader Function

local function AddScript(group, script)

    group:AddButton({

        Text = script.Name,

        Tooltip = script.Description,

        Func = function()

            Library:Notify({
                Title = "Loading",
                Description = script.Name,
                Time = 3
            })


            task.spawn(function()

                local success, err = pcall(script.Load)

                if success then

                    Library:Notify({
                        Title = "Loaded",
                        Description = script.Name,
                        Time = 3
                    })

                else

                    Library:Notify({
                        Title = "Error",
                        Description = tostring(err),
                        Time = 5
                    })

                end

            end)

        end

    })

end



--// Universal Scripts

local UniversalBox =
Tabs.Universal:AddLeftGroupbox("Scripts")


